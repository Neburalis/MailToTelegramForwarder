[Unit]
Description=Mail to Telegram Forwarder - Service for: '%i'
After=network-online.target nss-lookup.target
Wants=network-online.target nss-lookup.target
Documentation=https://github.com/awalon/MailToTelegramForwarder/

[Service]
WorkingDirectory=/opt/mailToTelegramForwarder
ExecStart=uv run mailToTelegramForwarder.py --config /etc/mail-to-telegram-forwarder/%i.conf
User=mail2telegram
Restart=on-failure

[Install]
WantedBy=multi-user.target
